generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String     @id @default(uuid())
  name        String
  email       String     @unique
  password    String
  role        Role
  status      UserStatus @default(PENDING)
  address     String?
  companyName String?
  matricule   String?
  phone       String?
  services    Service[]
  managed     Project[]  @relation("ChefProjects")
  projects    Project[]
  requests    Request[]
}

model Request {
  id          String        @id @default(uuid())
  status      RequestStatus @default(PENDING)
  userId      String
  createdAt   DateTime      @default(now())
  approvedBy  String?
  description String?
  user        User          @relation(fields: [userId], references: [id])
}

model Project {
  id          String          @id @default(uuid())
  title       String
  description String
  budget      Float?
  status      ProjectStatus   @default(PLANNED)
  clientId    String
  chefId      String
  services    Service
  chef        User            @relation("ChefProjects", fields: [chefId], references: [id])
  client      User            @relation(fields: [clientId], references: [id])
  updates     ProjectUpdate[]
}

model ProjectUpdate {
  id         String   @id @default(uuid())
  projectId  String
  updateType String
  details    String
  updatedBy  String
  timestamp  DateTime @default(now())
  services   Service
  project    Project  @relation(fields: [projectId], references: [id])
}

enum Role {
  ADMIN
  CHEF
  CLIENT
  GUEST
}

enum RequestStatus {
  PENDING
  APPROVED
  DECLINED
  BLOCKED
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum UserStatus {
  PENDING
  ACTIVE
  BLOCKED
}

enum Service {
  MACONNERIE
  RENOVATION
  RESTAURATION
  CONSTRUCTION_GENERALE
  REJOINTOIEMENT_RUSTIQUE
  TRAITEMENT_HYDROFUGE
  DEMOUSSAGE
}
